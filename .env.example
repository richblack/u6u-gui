# u6u-gui 環境變數
# 複製此檔為 .env.local 並填入實際值

# u6u-mcp Worker URL（認證、Workflow 列表、Action Log）
VITE_MCP_URL=https://u6u-mcp.your-subdomain.workers.dev

# Component Registry URL
VITE_REGISTRY_URL=https://component-registry.finally.click

# KBDB URL（updateWorkflow 暫時直接呼叫）
VITE_KBDB_URL=http://localhost:8787

# Cypher Executor URL
VITE_CYPHER_URL=http://localhost:8789

# 本地開發時使用：
# VITE_MCP_URL=http://localhost:8788
